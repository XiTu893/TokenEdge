{
  "name": "token-edge-pc",
  "version": "1.0.0",
  "description": "TokenEdge PC 端 - 边缘设备部署大模型 Token 服务",
  "main": "main.cjs",
  "bin": "server-simple.js",
  "scripts": {
    "dev": "bun run main.cjs",
    "start": "electron .",
    "test": "node server-simple.js",
    "build": "npm run build:win",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pkg": "bunx pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output dist/token-edge/token-edge",
    "pkg:win": "bunx pkg . --targets node18-win-x64 --output dist/token-edge/token-edge.exe",
    "pkg:linux": "bunx pkg . --targets node18-linux-x64 --output dist/token-edge/token-edge",
    "pkg:mac": "bunx pkg . --targets node18-macos-x64 --output dist/token-edge/token-edge-macos",
    "compile": "tsc",
    "watch": "tsc --watch"
  },
  "keywords": [
    "ai",
    "gemma",
    "llm",
    "llama.cpp",
    "electron"
  ],
  "author": "溪土红薯 <https://github.com/XiTu893>",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/electron": "^1.4.38",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "pkg": "^5.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-llama-cpp": "^3.18.1"
  },
  "pkg": {
    "scripts": "server-simple.js",
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist/token-edge"
  },
  "build": {
    "appId": "com.aiedge.app",
    "productName": "TokenEdge",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
