{
  "name": "token-edge-pc",
  "version": "1.0.0",
  "description": "TokenEdge PC 端 - 边缘设备部署大模型 Token 服务",
  "main": "main.js",
  "type": "commonjs",
  "bin": "server.js",
  "scripts": {
    "dev": "bun run main.js",
    "start": "electron .",
    "install:bun": "bun install",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pkg": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output dist/token-edge/token-edge",
    "pkg:win": "pkg . --targets node18-win-x64 --output dist/token-edge/token-edge.exe",
    "pkg:linux": "pkg . --targets node18-linux-x64 --output dist/token-edge/token-edge",
    "pkg:mac": "pkg . --targets node18-macos-x64 --output dist/token-edge/token-edge-macos"
  },
  "keywords": ["ai", "gemma", "llm", "llama.cpp", "electron"],
  "author": "溪土红薯 <https://github.com/XiTu893>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "pkg": "^5.8.1"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "node-llama-cpp": "^3.0.0",
    "chatllm-node": "^0.0.1"
  },
  "trustedDependencies": [
    "electron",
    "node-llama-cpp"
  ],
  "pkg": {
    "scripts": "server.js",
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist/token-edge"
  },
  "build": {
    "appId": "com.aiedge.app",
    "productName": "TokenEdge",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
